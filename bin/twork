#!/bin/bash

# Displays the context and project categories in a nice format from
# the todo readme.txt file

# Local workstation specific file
if [ $HOSTNAME = "lefty2226" ]; then
    file=/mnt/c/Users/leftygray/OneDrive/todo.txt/readme.txt
fi

if [ $HOSTNAME = "LeftyWork" ]; then
    file=/mnt/c/Users/z3241215/OneDrive/todo.txt/readme.txt
fi


a=$(awk '/_Core work actions_/ {print NR}' $file)
b=$(awk '/_Home actions_/ {print NR}' $file)
sed -n "$a , $b p" "$file"
